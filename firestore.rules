rules_version = '2';

// Firestore Security Rules
// Merge venueHireOpportunities with your full rules; keep the rest of your rules as-is.

service cloud.firestore {
  match /databases/{database}/documents {

    // Venue Hire Opportunities: public read so venue profile can show hire slots to everyone.
    // Writes only via backend API (Admin SDK).
    match /venueHireOpportunities/{docId} {
      allow read: if true;
      allow create, update, delete: if false;
    }
  }
}
